# Telegram Bot Token — lấy từ @BotFather trên Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID — lấy từ @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# API Key bảo vệ backend (tạo chuỗi random, ví dụ: openssl rand -hex 32)
# Để trống = không bật xác thực (chỉ dùng khi dev)
API_KEY=

# CORS: chỉ cho phép domain Vercel của bạn (ngăn domain lạ gọi API)
# Ví dụ: https://tinhieu-ck.vercel.app
# Để * = cho phép tất cả (chỉ dùng khi dev)
ALLOWED_ORIGINS=*

# Auth
ADMIN_EMAIL=phuongnst@gmail.com
ADMIN_NAME=phuongnst
JWT_SECRET=change-me-to-random-64-char-string
JWT_EXPIRE_HOURS=24

# Gmail SMTP (dùng App Password, không phải mật khẩu Gmail thật)
# Hướng dẫn: myaccount.google.com → Security → App Passwords
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# Logging
LOG_LEVEL=INFO
LOG_FILE=vn_stock_signals.log
