# Telegram Bot Token — lấy từ @BotFather trên Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID — lấy từ @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# API Key bảo vệ backend (tạo chuỗi random, ví dụ: openssl rand -hex 32)
# Để trống = không bật xác thực (chỉ dùng khi dev)
API_KEY=

# CORS: chỉ cho phép domain Vercel của bạn (ngăn domain lạ gọi API)
# Ví dụ: https://tinhieu-ck.vercel.app
# Để * = cho phép tất cả (chỉ dùng khi dev)
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FILE=vn_stock_signals.log
